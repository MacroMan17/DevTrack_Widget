{
  "name": "devtrack-widget",
  "version": "1.0.0",
  "description": "A floating desktop widget to track GitHub and LeetCode progress",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:react": "vite build",
    "build:exe": "npm run build:react && electron-builder --win",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.devtrack.widget",
    "productName": "DevTrack Widget",
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "tray.js",
      "package.json"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
