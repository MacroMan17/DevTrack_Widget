{
  "name": "devtrack-widget",
  "version": "1.0.0",
  "description": "A floating desktop widget to track GitHub and LeetCode progress",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "build:prod": "npm run build && electron-builder --win --publish never",
    "build:exe": "npm run build && electron-builder --win",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.devtrack.widget",
    "productName": "DevTrack Widget",
    "directories": {
      "buildResources": "src/assets"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DevTrack Widget"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "terser": "^5.46.2",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
